# VOC Analyst Environment Variables
# Copy this file to .env and fill in your values:
#   cp dot_env.example .env
#
# 배포 환경(Backyard)에서는 프로젝트 secret으로 주입됩니다.
# 코드가 LAMBDA_ 접두사 변수도 fallback으로 읽지만(과거 호환), 새 설정은 아래 이름을 쓰세요.

# =============================================================================
# Required: Slack Credentials
# Get these from https://api.slack.com/apps > Your App > Basic Information
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# 주간 리포트를 보낼 채널
VOC_SLACK_CHANNEL=#voc-alerts

# =============================================================================
# BigQuery (주간 VOC 리포트)
# =============================================================================
# VOC_BIGQUERY_PROJECT=wanted-data
# VOC_BIGQUERY_TABLE=wanted-data.wanted_ml.zendesk_voc_classified
# VOC_BIGQUERY_LOCATION=asia-northeast3
# VOC_BIGQUERY_CREDENTIALS_JSON={"type":"service_account",...}

# =============================================================================
# LaaS (optional — CRITICAL/MONITOR 항목 후속 분석)
# =============================================================================
# LAAS_API_KEY=your-laas-api-key
# LAAS_BASE_URL=https://api-laas.wanted.co.kr
# LAAS_PRESET_HASH=90571f07e6b60e047620162ecc29b423dba8280aba60dba503aac082082ad0c4
